# ==============================================================================
# UrbanHeat AI — System Environment Configuration
# ==============================================================================
# Copy this file to .env and adjust variables for local development or deployment.
# ==============================================================================

# Node.js API Gateway Config
PORT=3001
NODE_ENV=development
JWT_SECRET=urbanheat-ai-secret-key-2026-change-in-production

# Live Weather Telemetry (OpenWeatherMap API Key)
OPENWEATHER_API_KEY=your_openweathermap_api_key_here
WEATHER_CACHE_TTL=900

# Machine Learning Engine Configuration (Python FastAPI)
ML_ENGINE_HOST=localhost
ML_ENGINE_PORT=8000

# Geospatial API Integrations (Optional)
BHUVAN_API_KEY=your_isro_bhuvan_api_key_here
MOSDAC_API_KEY=your_isro_mosdac_api_key_here
