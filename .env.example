# UrbanHeat AI — Environment Configuration
# Copy this file to .env and fill in your values

# Database
DATABASE_URL=postgresql://urbanheat:urbanheat2026@localhost:5432/urbanheat_db
REDIS_URL=redis://localhost:6379/0

# JWT
SECRET_KEY=your-super-secret-key-change-in-production-urbanheat2026
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# AI Assistant (optional - uses mock fallback if not set)
LLM_API_KEY=
LLM_PROVIDER=mock

# App
APP_NAME=UrbanHeat AI
APP_VERSION=1.0.0
DEBUG=true
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ISRO Data (optional)
BHUVAN_API_KEY=
MOSDAC_API_KEY=
