# Server
PORT=3001
NODE_ENV=development

# JWT Authentication
JWT_SECRET=urbanheat-ai-secret-key-2026-change-in-production

# OpenWeatherMap API
OPENWEATHER_API_KEY=your_openweathermap_api_key_here
WEATHER_CACHE_TTL=900

# ML Engine Connection
ML_ENGINE_HOST=localhost
ML_ENGINE_PORT=8000

# ISRO Geospatial APIs (Optional)
BHUVAN_API_KEY=your_isro_bhuvan_api_key_here
MOSDAC_API_KEY=your_isro_mosdac_api_key_here
